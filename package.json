{
  "name": "n8n-nodes-figranium",
  "version": "0.5.0",
  "description": "Official n8n community node for Figranium. Connect to local or remote Figranium servers to automate tasks with dynamic variable injection and real-time response handling.",
  "license": "Apache-2.0",
  "keywords": [
    "n8n-community-node-package",
    "figranium",
    "automation"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && copyfiles -u 1 \"src/nodes/**/*.{png,svg}\" dist"
  },
  "dependencies": {
    "n8n-workflow": "^1.0.0"
  },
  "devDependencies": {
    "copyfiles": "^2.4.1",
    "n8n-core": "^1.0.0",
    "typescript": "^5.9.3"
  },
  "n8n": {
    "n8nNodesApiVersion": 1,
    "nodes": [
      "dist/nodes/Figranium/Figranium.node.js"
    ],
    "credentials": [
      "dist/credentials/FigraniumApi.credentials.js"
    ]
  }
}
